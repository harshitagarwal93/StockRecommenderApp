# Azure AI Foundry (GPT-4.1 deployment)
AZURE_AI_ENDPOINT=https://your-foundry-resource.openai.azure.com/
AZURE_AI_KEY=your-key
AZURE_AI_DEPLOYMENT=gpt-4.1
LLM_PROVIDER=azure_foundry

# Fallback: GitHub Models API (free)
# GITHUB_TOKEN=ghp_your_github_pat_here
# LLM_PROVIDER=github

# Kite Connect (for live portfolio)
KITE_API_KEY=your_kite_api_key
KITE_ACCESS_TOKEN=your_kite_access_token
KITE_API_SECRET=your_kite_api_secret

# Azure Cosmos DB
COSMOS_ENDPOINT=https://your-cosmosdb.documents.azure.com:443/
COSMOS_DATABASE=StockAdvisor
COSMOS_CONTAINER=recommendations
# For local dev
# COSMOS_KEY=your-key-here

# Notification (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_EMAIL=your-email@gmail.com

# Portfolio settings
INITIAL_CAPITAL=500000
MAX_BUY_AMOUNT=10000
MAX_BUYS_PER_DAY=3
MAX_SELLS_PER_DAY=2
MAX_PORTFOLIO_POSITIONS=15
MAX_SINGLE_ALLOCATION_PCT=15
